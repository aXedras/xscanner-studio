# CI environment defaults for xScanner (no secrets)
#
# This file is meant as a reference for GitHub Actions and local CI reproduction.
# It intentionally contains NO secrets.
#
# Notes:
# - The application only auto-loads `.env` / `.env.local` (see src/xscanner/server/config.py).
# - GitHub Actions loads this file explicitly in each job and exports variables via $GITHUB_ENV.
# - Secrets MUST NOT go into this file; inject them via GitHub Actions Secrets.

# Keep CI deterministic: do not auto-load local .env files.
XSCANNER_DOTENV=false

# Logging
LOG_LEVEL=INFO

# Mock determinism (optional)
XSCANNER_MOCK_CLOUD_STRATEGY=chatgpt

# --- OpenAI (API key injected via GitHub Secrets; placeholder so server starts) ---
OPENAI_API_KEY=ci-placeholder
OPENAI_MODEL=gpt-5.2
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=16000
OPENAI_MAX_OUTPUT_TOKENS=900

# --- Google / Gemini (API key injected via GitHub Secrets for e2e) ---
GOOGLE_API_KEY=ci-placeholder
GOOGLE_MODEL=gemini-2.0-flash

# --- Axedras (placeholders; not called in CI) ---
AXEDRAS_BASE_URL=https://instance1.acc.axedras.io
AXEDRAS_KEYCLOAK_URL=https://keycloak.acc.axedras.io
AXEDRAS_REALM=instance1
AXEDRAS_USERNAME=ci-placeholder
AXEDRAS_PASSWORD=ci-placeholder
AXEDRAS_CLIENT_ID=axedras-api

# LoRA Fine-tuned Model Server (local strategy)
LORA_BASE_URL=https://ln5k5kxgyy3sqz-8000.proxy.runpod.net

# LoRA Prompt files (defaults used if not set)
LORA_SYSTEM_PROMPT_FILE=config/lora_system_prompt.txt
LORA_USER_PROMPT_FILE=config/lora_user_prompt.txt
LORA_STAGE1_USER_PROMPT_FILE=config/lora_user_prompt.txt
LORA_STAGE2_USER_PROMPT_FILE=config/lora_user_prompt_OCR.txt

# ChatGPT Prompt files
CHATGPT_SYSTEM_PROMPT_FILE=config/chatgpt_system_prompt_image.txt
CHATGPT_USER_PROMPT_FILE=config/chatgpt_user_prompt_image.txt
CHATGPT_STAGE2_SYSTEM_PROMPT_FILE=config/chatgpt_system_prompt_image.txt
CHATGPT_STAGE2_USER_PROMPT_FILE=config/chatgpt_user_prompt_image.txt

# Server settings (for integration tests)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# Benchmark settings
MAX_TEST_IMAGES=10
STRATEGY_IMAGE_WORKERS=0

# Required secret (set via GitHub Actions Secrets, not in this file):
# - OPENAI_API_KEY       (real key overrides placeholder above in e2e job)
