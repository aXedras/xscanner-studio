# xScanner Studio — Example environment
# Copy to `.env.local` and fill in values.
#
# Notes:
# - Variables prefixed with `VITE_` are exposed to the browser.
# - Non-`VITE_` variables are only used by the Vite dev server (Node.js).
#

# --- API (local server) ---
# FastAPI server URL (local dev)
VITE_API_URL=http://localhost:9000

# API adapter rollout flags (Variant B migration)
# Enable exactly one migration slice at a time and validate before enabling the next.
VITE_USE_ORDERS_READ_API=false
VITE_USE_EXTRACTIONS_READ_API=false
VITE_USE_BIL_READ_API=false
VITE_USE_EXTRACTIONS_MUTATION_API=false
VITE_USE_AUTH_API=false

# --- Logging (browser / client-side) ---
# Log level hierarchy: debug → info → warn → error → none
# Default: debug in dev, error in prod
VITE_LOG_LEVEL=debug

# Optional: comma-separated list of enabled categories.
# Example: ExtractionService,AuthService,HttpXScannerClient
# If empty, all categories are enabled.
VITE_LOG_CATEGORIES=

# Optional: also persist logs to a local file while running `npm run dev`.
# This uses the Vite dev server endpoint (same origin) and writes to `../logs/studio.log`.
# Values: true|false
VITE_LOG_TO_FILE=false

# Dev server endpoint used for file logging. Only relevant when VITE_LOG_TO_FILE=true.
VITE_LOG_INGEST_PATH=/__studio_log


# --- Logging (Vite dev server / file sink) ---
# Enable/disable file logging endpoint on the dev server.
STUDIO_LOG_INGEST_ENABLED=false

# Ingest endpoint path. Must match VITE_LOG_INGEST_PATH.
STUDIO_LOG_INGEST_PATH=/__studio_log

# Output log file path (relative to `studio/`)
STUDIO_LOG_FILE=../logs/studio.log

# Rolling config
# - When the log exceeds this size, it is rotated to `.1`, `.2`, ...
STUDIO_LOG_MAX_BYTES=1048576
STUDIO_LOG_BACKUP_COUNT=5
