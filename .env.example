# =============================================================================
# xScanner Environment Configuration Template
# Copy this file to .env and fill in your actual values
# =============================================================================

# OpenAI API Key (for ChatGPT Vision strategy)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1200
OPENAI_MAX_OUTPUT_TOKENS=900

# Google API Key (for Gemini Flash strategy)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...
GOOGLE_MODEL=gemini-2.0-flash

# Ollama Configuration (for local Llama Vision)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_11B=llama3.2-vision:11b
OLLAMA_REQUEST_TIMEOUT=600

OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_CONCURRENT=2
OLLAMA_MAX_LOADED_MODELS=1

# aXedras Bullion Integrity Ledger (BIL) Integration
AXEDRAS_BASE_URL=https://instance1.acc.axedras.io
AXEDRAS_KEYCLOAK_URL=https://keycloak.acc.axedras.io
AXEDRAS_REALM=instance1
AXEDRAS_CLIENT_ID=axedras-api
AXEDRAS_USERNAME=admin@axedras.com
AXEDRAS_PASSWORD=


# Testing / Benchmark Configuration
# Limit number of test images (default: all)
MAX_TEST_IMAGES=10

# Parallelism (optional)
# Image-level parallelism for benchmarking (default: 0 = disabled)
STRATEGY_IMAGE_WORKERS=0
# Deprecated legacy name (fallback): OCR_IMAGE_WORKERS

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4
REDIS_URL=

# Logging Configuration
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=DEBUG
# LOG_FILE: Path to log file (default: logs/xscanner.log)
LOG_FILE=logs/xscanner.log
# LOG_FILE_MAX_BYTES: Max size per log file in bytes (default: 10485760 = 10MB)
LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT: Number of backup files to keep (default: 5)
LOG_FILE_BACKUP_COUNT=5

# Prompt Configuration
PROMPT_TEMPLATE_FILE=config/prompt_template.txt
SYSTEM_PROMPT_FILE=config/system_prompt.txt
PROMPT_TEMPLATE_IMAGE_FILE=config/prompt_template_image.txt
SYSTEM_PROMPT_IMAGE_FILE=config/system_prompt_image.txt
PROMPTS_DIR=config
