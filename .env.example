# =============================================================================
# xScanner environment template (single source of truth)
#
# Usage (do not commit secrets):
# - Local server dev: copy to .env.local
# - Pre-prod:         use .env.preprod.example -> .env.preprod
# - Studio dev (Vite): use studio/.env.example -> studio/.env.local
# =============================================================================

# Dotenv loader behavior (server)
# - Default: true (loads .env.local and .env)
# - Set false to force explicit environment variables only
XSCANNER_DOTENV=true

# --- Providers ---

# OpenAI (ChatGPT Vision)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_MODEL=gpt-5.2
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_OUTPUT_TOKENS=900

# Optional (cost estimation)
# Used only for populating `result.meta.llm_usage.cost_usd` in order extraction responses.
# Set these to match your selected `OPENAI_MODEL`.
#
# Prices are USD per 1,000,000 tokens.
# Reference: https://openai.com/api/pricing
OPENAI_PRICE_INPUT_PER_1M_USD=0.250
OPENAI_PRICE_OUTPUT_PER_1M_USD=2.000

# Google (Gemini)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# LoRA Fine-tuned Model Server (local strategy)
# Default points to local LoRA server
LORA_BASE_URL=https://ln5k5kxgyy3sqz-8000.proxy.runpod.net

# LoRA Prompt files (optional overrides - defaults used if not set)
LORA_SYSTEM_PROMPT_FILE=config/lora_system_prompt.txt
LORA_USER_PROMPT_FILE=config/lora_user_prompt.txt
LORA_STAGE1_USER_PROMPT_FILE=config/lora_user_prompt.txt
LORA_STAGE2_USER_PROMPT_FILE=config/lora_user_prompt_OCR.txt

# ChatGPT Prompt files
CHATGPT_SYSTEM_PROMPT_FILE=config/chatgpt_system_prompt_image.txt
CHATGPT_USER_PROMPT_FILE=config/chatgpt_user_prompt_image.txt
CHATGPT_STAGE2_SYSTEM_PROMPT_FILE=config/chatgpt_system_prompt_image.txt
CHATGPT_STAGE2_USER_PROMPT_FILE=config/chatgpt_user_prompt_image.txt

# --- Optional integration: aXedras BIL ---
AXEDRAS_BASE_URL=https://instance1.acc.axedras.io
AXEDRAS_KEYCLOAK_URL=https://keycloak.acc.axedras.io
AXEDRAS_REALM=instance1
AXEDRAS_CLIENT_ID=axedras-api
AXEDRAS_USERNAME=
AXEDRAS_PASSWORD=

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# --- Persistence (Supabase) ---

# API/server persistence URL.
# - Local dev (no Docker): typically http://127.0.0.1:56321
# - In pre-prod docker-compose: SUPABASE_URL is set to SUPABASE_INTERNAL_URL automatically.
SUPABASE_URL=http://127.0.0.1:56321
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=extractions

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/xscanner.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5
