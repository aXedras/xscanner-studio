# =============================================================================
# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# =============================================================================

# OpenAI API Key (for ChatGPT Vision strategy)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Google API Key (for Gemini Flash strategy)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Ollama Configuration (for local Llama Vision)
# Default: http://localhost:11434
# For multiple instances: http://localhost:11434,http://localhost:11435
OLLAMA_URLS=http://localhost:11434

# Ollama Parallelism Settings
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_CONCURRENT=2
OLLAMA_MAX_LOADED_MODELS=1

# OCR Testing Configuration
# Limit number of test images (default: all)
MAX_TEST_IMAGES=10

# Strategy worker pool size (default: 1)
OCR_STRATEGY_WORKERS=1

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# aXedras Bullion Integrity Ledger (BIL) Integration
# AXEDRAS_BIL_API_URL=https://bil.axedras.com/api
# AXEDRAS_BIL_API_KEY=your-bil-api-key

# Redis (optional, for job queuing)
# REDIS_URL=redis://localhost:6379/0

# Development Settings
# LOG_LEVEL=INFO
# DEBUG=false
