{
  "$schema": "https://json.schemastore.org/jscpd.json",
  "threshold": 5,
  "reporters": ["console"],
  "pattern": "src/**/*.{ts,tsx}",
  "absolute": false,
  "gitignore": true,
  "minLines": 10,
  "minTokens": 50,
  "ignore": [
    "**/*.d.ts",
    "src/lib/supabase/database.types.ts",
    "src/locales/**"
  ]
}
