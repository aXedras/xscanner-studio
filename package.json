{
  "name": "studio",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "help": "node scripts/help.mjs",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit",
    "hooks:uninstall": "git config --unset core.hooksPath || true",
    "check": "node scripts/help-check.mjs",
    "check:fast": "npm run dup:check && npm run lint && npm run type-check && npm run test:unit",
    "check:all": "npm run format:check && npm run lint && npm run type-check && npm run i18n:all && npm run db:check && npm run build && npm run test:unit",
    "dev": "vite",
    "build": "npm run dup:check && tsc -b && vite build",
    "dup:check": "jscpd --config .jscpd.json",
    "dup:report": "jscpd --config .jscpd.json --reporters json --output reports/jscpd --threshold 100",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "type-check": "tsc -b",
    "test": "node scripts/help-test.mjs",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:all": "npm run test:unit && npm run test:integration",
    "db": "node scripts/db/help.mjs",
    "db:types": "node scripts/db/help.mjs",
    "db:generate": "npm run db:types:generate",
    "db:check": "npm run db:types:check",
    "db:types:generate": "node scripts/db/gen-db-types.mjs",
    "db:types:check": "node scripts/db/check-db-types.mjs",
    "i18n": "node scripts/help-i18n.mjs",
    "i18n:all": "npm run check:i18n:all",
    "i18n:missing": "npm run check:i18n:missing",
    "i18n:unused": "npm run check:i18n:unused",
    "check:i18n:missing": "node scripts/i18n/check-missing.mjs",
    "check:i18n:unused": "node scripts/i18n/check-unused.mjs",
    "check:i18n:all": "node scripts/i18n/check-i18n.mjs && npm run check:i18n:missing && npm run check:i18n:unused"
  },
  "dependencies": {
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/supabase-js": "^2.90.1",
    "autoprefixer": "^10.4.23",
    "i18next": "^25.7.4",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.3",
    "react-router-dom": "^7.12.0",
    "tailwindcss": "3.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jscpd": "^4.0.8",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
