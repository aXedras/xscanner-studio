# Pre-prod example env for docker-compose.preprod.yml
# Copy to .env.preprod (do NOT commit secrets)

# --- Supabase (public, used by browser/Studio) ---
# Used by the browser to talk to Supabase.
# - Remote/VM usage: MUST be reachable from your laptop/browser.
#   Example: http://<vm-ip-or-domain>:56321
# - Local-only usage (browser runs on same machine as Supabase): localhost is OK.
SUPABASE_PUBLIC_URL=http://<vm-ip-or-domain>:56321

# --- Supabase (internal, used by xscanner-api inside Docker) ---
# This is the kong container name + internal port on the supabase network
SUPABASE_INTERNAL_URL=http://supabase_kong_xScanner:8000

# Supabase keys
# REQUIRED (Studio): Supabase anon public key (starts with `sb_publishable_...`)
# You can get this from the Supabase dashboard or from your local stack.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=extractions

# --- Providers ---

# OpenAI (ChatGPT Vision)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_OUTPUT_TOKENS=900

GOOGLE_API_KEY=

# Optional (cost estimation)
# Used only for populating `result.meta.llm_usage.cost_usd` in order extraction responses.
# Set these to match your selected OpenAI model.
# Prices are USD per 1,000,000 tokens.
# Reference: https://openai.com/api/pricing
OPENAI_PRICE_INPUT_PER_1M_USD=0.250
OPENAI_PRICE_OUTPUT_PER_1M_USD=2.000

# LoRA Fine-tuned Model Server (local strategy)
# Default points to local LoRA server
LORA_BASE_URL=https://ln5k5kxgyy3sqz-8000.proxy.runpod.net

# LoRA Prompt files (optional overrides - defaults used if not set)
LORA_SYSTEM_PROMPT_FILE=config/lora_system_prompt.txt
LORA_USER_PROMPT_FILE=config/lora_user_prompt_extended.txt
LORA_STAGE1_USER_PROMPT_FILE=config/lora_user_prompt_extended.txt
LORA_STAGE2_USER_PROMPT_FILE=config/lora_user_prompt_OCR.txt

# ChatGPT 2-Stage Prompt files (optional overrides - defaults used if not set)
CHATGPT_STAGE2_SYSTEM_PROMPT_FILE=config/system_prompt_image.txt
CHATGPT_STAGE2_USER_PROMPT_FILE=config/chatgpt_prompt_image.txt

# Mock determinism (optional)
# If you run requests with `use_mock: true` in pre-prod, this forces cloud mock selection.
XSCANNER_MOCK_CLOUD_STRATEGY=chatgpt

# --- Optional integration: aXedras Bullion Integrity Ledger (BIL) ---
AXEDRAS_BASE_URL=https://instance1.acc.axedras.io
AXEDRAS_KEYCLOAK_URL=https://keycloak.acc.axedras.io
AXEDRAS_REALM=instance1
AXEDRAS_CLIENT_ID=axedras-api
AXEDRAS_USERNAME=
AXEDRAS_PASSWORD=

# --- Logging ---
LOG_LEVEL=INFO
STUDIO_LOG_LEVEL=info
