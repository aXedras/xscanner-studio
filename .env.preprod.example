# Pre-prod example env for docker-compose.preprod.yml
# Copy to .env.preprod (do NOT commit secrets)

# --- Supabase (public, used by browser/Studio) ---
# Used by the browser to talk to Supabase.
# - Remote/VM usage: MUST be reachable from your laptop/browser.
#   Example: http://<vm-ip-or-domain>:56321
# - Local-only usage (browser runs on same machine as Supabase): localhost is OK.
SUPABASE_PUBLIC_URL=http://<vm-ip-or-domain>:56321

# --- Supabase (internal, used by xscanner-api inside Docker) ---
# This is the kong container name + internal port on the supabase network
SUPABASE_INTERNAL_URL=http://supabase_kong_xScanner:8000

# Supabase keys
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=extractions

# --- Providers ---
OPENAI_API_KEY=
GOOGLE_API_KEY=

# LoRA Fine-tuned Model Server (local strategy)
# Default points to local LoRA server
LORA_BASE_URL=https://ct2ebwgxuuwsqe-8000.proxy.runpod.net

# --- Optional integration: aXedras Bullion Integrity Ledger (BIL) ---
AXEDRAS_BASE_URL=https://instance1.acc.axedras.io
AXEDRAS_KEYCLOAK_URL=https://keycloak.acc.axedras.io
AXEDRAS_REALM=instance1
AXEDRAS_CLIENT_ID=axedras-api
AXEDRAS_USERNAME=
AXEDRAS_PASSWORD=

# --- Logging ---
LOG_LEVEL=INFO
STUDIO_LOG_LEVEL=info
